---
const BASE_URL = 'https://terex-plus.ru';

interface Props {
  pageName?: string;
  pageUrl?: string;
  categoryName?: string;
  categoryUrl?: string;
  itemName?: string;
}

const { pageName, pageUrl, categoryName, categoryUrl, itemName } = Astro.props;

// Build breadcrumb JSON-LD
const breadcrumbItems: object[] = [
  { '@type': 'ListItem', position: 1, name: 'Главная', item: `${BASE_URL}/` },
];

if (itemName && pageName && pageUrl) {
  breadcrumbItems.push({
    '@type': 'ListItem',
    position: 2,
    name: pageName,
    item: `${BASE_URL}${pageUrl}`,
  });
  breadcrumbItems.push({ '@type': 'ListItem', position: 3, name: itemName });
} else if (itemName && categoryName && categoryUrl) {
  breadcrumbItems.push({
    '@type': 'ListItem',
    position: 2,
    name: 'Спецтехника',
    item: `${BASE_URL}/technics.html`,
  });
  breadcrumbItems.push({
    '@type': 'ListItem',
    position: 3,
    name: categoryName,
    item: `${BASE_URL}${categoryUrl}`,
  });
  breadcrumbItems.push({ '@type': 'ListItem', position: 4, name: itemName });
} else if (categoryName) {
  breadcrumbItems.push({
    '@type': 'ListItem',
    position: 2,
    name: 'Спецтехника',
    item: `${BASE_URL}/technics.html`,
  });
  breadcrumbItems.push({ '@type': 'ListItem', position: 3, name: categoryName });
} else if (pageName) {
  breadcrumbItems.push({ '@type': 'ListItem', position: 2, name: pageName });
}

const breadcrumbLD = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems,
};
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLD)} />
<section class="field"></section>
<section class="strip bg-light">
  <div class="container">
    <div class="row">
      <div class="col">
        <nav aria-label="Хлебные крошки">
          <ol class="breadcrumb">
            <li class="breadcrumb__item">
              <a href="/">Главная</a>
            </li>
            {
              itemName && pageName && pageUrl ? (
                <>
                  <li class="breadcrumb__item">
                    <a href={pageUrl}>{pageName}</a>
                  </li>
                  <li class="breadcrumb__item breadcrumb__item--active">{itemName}</li>
                </>
              ) : itemName && categoryName && categoryUrl ? (
                <>
                  <li class="breadcrumb__item">
                    <a href="/technics.html">Спецтехника</a>
                  </li>
                  <li class="breadcrumb__item">
                    <a href={categoryUrl}>{categoryName}</a>
                  </li>
                  <li class="breadcrumb__item breadcrumb__item--active">{itemName}</li>
                </>
              ) : categoryName ? (
                <>
                  <li class="breadcrumb__item">
                    <a href="/technics.html">Спецтехника</a>
                  </li>
                  <li class="breadcrumb__item breadcrumb__item--active">{categoryName}</li>
                </>
              ) : pageName ? (
                <li class="breadcrumb__item breadcrumb__item--active">{pageName}</li>
              ) : null
            }
          </ol>
        </nav>
      </div>
    </div>
  </div>
</section>
