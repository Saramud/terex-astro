---
import Modal from './Modal.astro';

interface Props {
  isIndex?: boolean;
  showModal?: boolean;
}

const { isIndex = false, showModal = false } = Astro.props;
---

<footer class="footer">
  <div class="container">
    <div class="row">
      <div class="col-lg-4 col-md-6 col-sm-6 order-sm-2">
        <div class="footer__reference">
          <h4>ТЕРЕКС-ПЛЮС</h4>
          <h5 class="text-white">аренда спецтехники в СПБ и ЛО</h5>
          <div class="col-sm logo">
            <a href="/" title="На главную">
              <img src="/img/logo.png" width="100" height="100" alt="Терекс-Плюс" loading="lazy" />
            </a>
          </div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6 col-sm-6 order-sm-1">
        <h4>КОНТАКТЫ</h4>
        <div class="footer__contact">
          <a class="icon icon-phone" href="tel:89215734502">8 (921) 573-45-02</a>
          <a class="icon icon-mail" href="mailto:order@terex-plus.ru">order@terex-plus.ru</a>
        </div>
      </div>
      <div class="col-lg-4 col-md-6 col-sm-4 order-sm-0">
        <h4>МЕНЮ</h4>
        <div class="footer__reference">
          <ul class="footer__menu">
            <li class="footer-menu__item"><a href="/">Главная</a></li>
            <li class="footer-menu__item"><a href="/technics.html">Спецтехника</a></li>
            <li class="footer-menu__item"><a href="/articles.html">Статьи</a></li>
            <li class="footer-menu__item"><a href="/about.html">О компании</a></li>
            <li class="footer-menu__item"><a href="/contacts.html">Контакты</a></li>
            {
              isIndex ? (
                <li class="footer-menu__item">
                  <a class="indexPage" href="#requestform">
                    Оставить заявку
                  </a>
                </li>
              ) : (
                showModal && (
                  <li class="footer-menu__item">
                    <button
                      class="btn footer_button"
                      type="button"
                      data-modal="#exampleModalCenter"
                    >
                      Отправить заявку
                    </button>
                  </li>
                )
              )
            }
          </ul>
        </div>
      </div>
    </div>
    <div class="row text-center">
      <div class="copyright col-12">
        <p>2019–2026 © «Терекс-Плюс». Все права защищены</p>
      </div>
    </div>
  </div>
  {showModal && <Modal />}
</footer>

