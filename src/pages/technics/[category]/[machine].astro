---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Strip from '../../../components/Strip.astro';
import Footer from '../../../components/Footer.astro';
import Modal from '../../../components/Modal.astro';
import { categories } from '../../../data/equipment';
import { propertyLabels } from '../../../data/types';
import type { TechPropertyKey } from '../../../data/types';

export function getStaticPaths() {
  return categories.flatMap((cat) =>
    cat.items.map((item) => ({
      params: { category: cat.urlSlug, machine: item.id },
      props: { category: cat, item },
    }))
  );
}

const { category, item } = Astro.props;

const pageTitle = `Аренда ${item.title} в СПб — Терекс-Плюс`;
const description = `Аренда ${item.title} в Санкт-Петербурге и Ленинградской области — Цена за смену от ${item.price} руб. Аренда в круглосуточном режиме.`;
const canonical = `https://terex-plus.ru/technics/${category.urlSlug}/${item.id}.html`;

const serviceLD = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Аренда ${item.title} в Санкт-Петербурге`,
  description,
  provider: {
    '@type': 'Organization',
    name: 'Терекс-Плюс',
    url: 'https://terex-plus.ru',
  },
  areaServed: [
    { '@type': 'City', name: 'Санкт-Петербург' },
    { '@type': 'AdministrativeArea', name: 'Ленинградская область' },
  ],
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    seller: { '@type': 'Organization', name: 'Терекс-Плюс' },
  },
};

// Sibling items in same category (for nav selector)
const prefix = item.id.slice(0, 4);
const siblings = category.items.filter((i) => i.id.startsWith(prefix));
---

<BaseLayout
  title={pageTitle}
  description={description}
  canonical={canonical}
  ogImage={`https://terex-plus.ru${item.img}`}
  jsonLdExtra={[serviceLD]}
>
  <Header page="technicItem" showModal={false} />
  <Strip
    itemName={item.title}
    categoryName={category.name}
    categoryUrl={`/technics/${category.urlSlug}.html`}
  />

  <main>
    <section class="technic">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-12 text-center">
            <h1 class="technic__title">{item.title}</h1>
          </div>
        </div>
        <div class="row justify-content-center">
          <div class="col-12 col-lg-6 technic__photo">
            <img src={item.img} alt={item.title} loading="eager" width={600} height={400} />
          </div>
          <div class="col-12 col-lg-6">
            <div class="technic__buy">
              <p class="technic__price">
                от <b>{item.price.toLocaleString('ru-RU')}&nbsp;₽</b> / смена
                <span class="technic__price-unit">смена — 8 часов</span>
              </p>
              <button class="btn btn-warning" type="button" data-modal="#exampleModalCenter">
                Арендовать
              </button>
            </div>
            <h2 class="technic__specs-title">Технические характеристики</h2>
            <table class="specs-table">
              <tbody>
                {
                  category.properties.map((prop) => (
                    <tr>
                      <td>{propertyLabels[prop as TechPropertyKey]}</td>
                      <td>{item.props[prop as TechPropertyKey] ?? '—'}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </div>
        {
          siblings.length > 1 && (
            <div class="row">
              <div class="col nav-menu">
                <p class="siblings-label">Другие модели в этой категории:</p>
                <ul class="technic__selector">
                  {siblings.map((s) => (
                    <li>
                      <a class:list={['techs', s.id === item.id && 'techs-active']} href={s.link}>
                        {s.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          )
        }
      </div>
    </section>
  </main>

  <Modal defaultTechnics={item.title} />
  <Footer showModal={false} />
</BaseLayout>
