---
import { categories as equipmentCategories } from '@/data/equipment';

interface Props {
  activePage?: string;
}

const { activePage } = Astro.props;
const isTechnicsActive = activePage === 'technics' || activePage === 'technicItem';

const categories = equipmentCategories.map((category) => ({
  href: `/technics/${category.urlSlug}.html`,
  label: category.name,
}));
---

<div class="tech-dropdown">
  <a
    href="/technics.html"
    class:list={['sub_menu', isTechnicsActive && 'active']}
    aria-haspopup="true"
  >
    Спецтехника
  </a>
  <button
    class="dropdown-arrow"
    type="button"
    aria-label="Показать категории техники"
    aria-expanded="false"
  >
    <i class="fa fa-angle-down" aria-hidden="true"></i>
  </button>
  <div class="my_dropdown" role="menu">
    {
      categories.map(({ href, label }) => (
        <div class="panel-heading">
          <a class="dropdown-item" href={href} role="menuitem">
            {label}
          </a>
        </div>
      ))
    }
  </div>
</div>
