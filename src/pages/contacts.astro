---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Strip from '../components/Strip.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm';

const title = 'Контакты — Терекс-Плюс, аренда спецтехники в СПб';
const description =
  'Компания «Терекс-Плюс» работает круглосуточно. Свяжитесь с нами по телефону, email, Telegram или WhatsApp. Адрес: г. Санкт-Петербург, Таллинское шоссе, 153/3.';
const keywords = 'Терекс-Плюс контакты, аренда спецтехники Санкт-Петербург, телефон аренда техники';
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonical="https://terex-plus.ru/contacts.html"
>
  <Header page="contacts" showModal={false} />
  <Strip pageName="Контакты" />

  <main>
    <section class="contacts">
      <div class="container">
        <div class="row">
          <div class="col-12 text-center">
            <h1 class="info__title">Контакты</h1>
          </div>
        </div>
        <div class="row">
          <div class="col-lg-6 col-sm-12">
            <div class="contact">
              <span class="icon icon-clock">24/7</span>
            </div>
            <div class="contact">
              <a class="icon icon-phone" href="tel:8(812)989-03-32">8(812)989-03-32</a>
            </div>
            <div class="contact">
              <a class="icon icon-mail" href="mailto:info@terex-plus.ru">info@terex-plus.ru</a>
            </div>
            <div class="contact">
              <a class="icon icon-telegram" href="tg://resolve?domain=SSaramud"
                >Написать в Telegram</a
              >
            </div>
            <div class="contact">
              <a
                class="icon icon-whatsapp"
                href="https://wa.me/79681938577?text=Здравствуйте.%20Вопрос%20по%20поводу."
                >Написать в Whatsapp</a
              >
            </div>
            <div class="contact">
              <a
                class="icon icon-address"
                href="https://www.google.ru/maps/place/%D0%A2%D0%B0%D0%BB%D0%BB%D0%B8%D0%BD%D1%81%D0%BA%D0%BE%D0%B5+%D1%88.,+153,+%D0%A1%D1%82%D0%B0%D1%80%D0%BE-%D0%9F%D0%B0%D0%BD%D0%BE%D0%B2%D0%BE,+%D0%A1%D0%B0%D0%BD%D0%BA%D1%82-%D0%9F%D0%B5%D1%82%D0%B5%D1%80%D0%B1%D1%83%D1%80%D0%B3,+198205/@59.8141542,30.1703623,17z"
              >
                г. Санкт-Петербург, Таллинское шоссе, 153/3
              </a>
            </div>
          </div>
          <div class="col-lg-6 col-sm-12 text-center contact__feedback">
            <h2>Обратная связь</h2>
            <ContactForm client:load variant="feedback" />
          </div>
        </div>
        <div class="row">
          <div class="col-12 text-center">
            <div class="maps" style="margin-top:50px;">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2006.1062795222956!2d30.17036231639478!3d59.8141541818311!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x46963b8180a7a87f%3A0x3148c64660b3d8e2!2z0KLQsNC70LvQuNC90YHQutC-0LUg0YguLCAxNTMsINCh0YLQsNGA0L4t0J_QsNC90L7QstC-LCDQodCw0L3QutGCLdCf0LXRgtC10YDQsdGD0YDQsywgMTk4MjA1!5e0!3m2!1sru!2sru!4v1581079404111!5m2!1sru!2sru"
                style="width:100%; border:0; height:450px;"
                loading="lazy"
                title="Карта проезда к Терекс-Плюс"></iframe>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
