---
import TechMenu from './TechMenu.astro';
import Modal from './Modal.astro';

interface Props {
  page?: 'index' | 'about' | 'contacts' | 'technics' | 'technicItem';
  showModal?: boolean;
}

const { page, showModal = true } = Astro.props;
---

<header class="header header_template">
  <div class="container header__bar">
    <a href="/" class="logo" title="На главную">
      <img src="/img/logo_3.webp" width="48" height="48" alt="Лого Терекс-Плюс" />
      <span class="logo_name">
        ТЕРЕКС&#8209;ПЛЮС
        <span class="sub">Аренда спецтехники в СПб</span>
      </span>
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-label="Открыть меню"
      aria-expanded="false"
      aria-controls="site-nav"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="site-nav" id="site-nav">
      <ul class="menu">
        <li class="menu__item">
          <a class={page === 'index' ? 'active' : ''} href="/">Главная</a>
        </li>
        <li class="menu__item">
          <TechMenu activePage={page} />
        </li>
        <li class="menu__item">
          <a class={page === 'about' ? 'active' : ''} href="/about.html">О компании</a>
        </li>
        <li class="menu__item">
          <a class={page === 'contacts' ? 'active' : ''} href="/contacts.html">Контакты</a>
        </li>
      </ul>
    </nav>

    <div class="header__contacts">
      <a class="icon icon-phone" href="tel:8(812)989-03-32">8 (812) 989-03-32</a>
      <button class="icon icon-mail header_button" type="button" data-modal="#exampleModalCenter">
        Отправить заявку
      </button>
    </div>
  </div>
  {showModal && <Modal />}
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
    const nav = document.getElementById('site-nav');
    if (toggle && nav) {
      toggle.addEventListener('click', () => {
        const open = nav.classList.toggle('open');
        toggle.classList.toggle('open', open);
        toggle.setAttribute('aria-expanded', String(open));
        toggle.setAttribute('aria-label', open ? 'Закрыть меню' : 'Открыть меню');
      });
    }

    // Mobile accordion for the categories dropdown
    document.querySelectorAll<HTMLButtonElement>('.dropdown-arrow').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const dropdown = btn.closest('.tech-dropdown');
        if (!dropdown) return;
        const open = dropdown.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(open));
      });
    });
  });
</script>
