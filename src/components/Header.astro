---
import TechMenu from './TechMenu.astro';
import Modal from './Modal.astro';

interface Props {
  page?: 'index' | 'about' | 'contacts' | 'technics' | 'technicItem';
  showModal?: boolean;
}

const { page, showModal = true } = Astro.props;
---

<header class="header header_template">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-sm logo">
        <a href="/" title="На главную">
          <img src="/img/logo_3.webp" width="100" height="100" alt="Лого Терекс-Плюс" loading="lazy" />
          <span class="logo_name">
            ТЕРЕКС&#8209;ПЛЮС
            <span class="sub">Аренда Спецтехники в СПб</span>
          </span>
        </a>
      </div>
      <div class="col-sm info">
        <a class="icon icon-phone" href="tel:8(812)989-03-32">8(812)989-03-32</a>
        {
          showModal && (
            <div class="icon icon-mail header_button" data-modal="#exampleModalCenter">
              Отправить заявку
            </div>
          )
        }
      </div>
    </div>
    <div class="row">
      <div class="col-12 text-center">
        <nav>
          <ul class="menu justify-content-center">
            <li class="menu__item">
              <a class={page === 'index' ? 'active' : ''} href="/">Главная</a>
            </li>
            <li class="menu__item">
              <TechMenu activePage={page} />
            </li>
            <li class="menu__item">
              <a class={page === 'about' ? 'active' : ''} href="/about.html">О компании</a>
            </li>
            <li class="menu__item">
              <a class={page === 'contacts' ? 'active' : ''} href="/contacts.html">Контакты</a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </div>
  {showModal && <Modal />}
</header>
