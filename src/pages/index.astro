---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Catalog from '../components/Catalog';
import ContactForm from '../components/ContactForm';
import { categories } from '../data/equipment';

const title = 'Аренда спецтехники в Санкт-Петербурге — Терекс-Плюс';
const description =
  'На нашем сайте по аренде спецтехники компании «Терекс-Плюс» представлен большой выбор техники от мини-погрузчиков до автокранов 40 тонн. Если не нашли нужную Вам технику в общем каталоге — воспользуйтесь нашей удобной формой для отправки заявки!';
const keywords =
  'аренда спецтехники, аренда строительной техники, спецтехника в аренду, аренда дорожной техники, аренда спецтехники в Санкт-Петербурге, аренда гусеничного экскаватора';

const faq = [
  {
    q: 'Что входит в стоимость аренды?',
    a: 'В стоимость смены входит работа техники и услуги оператора. Смена — 8 часов. Доставка до объекта рассчитывается отдельно и зависит от удалённости; колёсная техника часто добирается своим ходом, что дешевле.',
  },
  {
    q: 'Какой минимальный срок аренды?',
    a: 'Минимальный заказ — одна смена (8 часов). При аренде на длительный срок — от недели и больше — согласуем индивидуальный тариф со скидкой.',
  },
  {
    q: 'Как быстро вы подаёте технику?',
    a: 'Диспетчер работает круглосуточно. Колёсную технику (экскаваторы-погрузчики, манипуляторы, самосвалы) часто подаём в день обращения, гусеничную — на следующий день, так как нужна перевозка тралом.',
  },
  {
    q: 'Какие документы нужны для аренды?',
    a: 'Работаем по официальному договору аренды. Для юридических лиц — реквизиты компании, для физических лиц — паспорт. Закрывающие документы предоставляем.',
  },
  {
    q: 'Куда вы доставляете технику?',
    a: 'Работаем по всему Санкт-Петербургу и Ленинградской области: от городских объектов в центре до загородных участков и труднодоступных площадок — для них есть техника повышенной проходимости.',
  },
  {
    q: 'Что будет, если техника сломается на объекте?',
    a: 'Технику ежедневно обслуживают наши механики, но если поломка всё же случилась — оперативно отремонтируем машину на месте или заменим её на аналогичную. Простой по нашей вине вы не оплачиваете.',
  },
];

const faqLD = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonical="https://terex-plus.ru/"
  jsonLdExtra={[faqLD]}
>
  <Header page="index" showModal={false} />

  <section class="hero">
    <div class="container">
      <div class="hero__inner">
        <div class="hero__content">
          <h1>Аренда спецтехники в&nbsp;Санкт-Петербурге</h1>
          <p class="hero__subtitle">
            Собственный автопарк — от мини-погрузчиков до автокранов 40&nbsp;тонн. Подача техники
            возможна уже в день заявки, работаем по всему СПб и Ленобласти.
          </p>
          <div class="hero__actions">
            <a class="btn btn-warning" href="#mainPageCatalog">Каталог техники</a>
            <a class="btn btn-outline-light icon icon-phone" href="tel:89215734502">
              8 (921) 573-45-02
            </a>
          </div>
        </div>
        <img
          class="hero__img"
          src="/img/hero-excavator.svg"
          width="400"
          height="290"
          alt="Экскаватор в аренду"
          fetchpriority="high"
        />
      </div>
    </div>
    <div class="hero__trust">
      <div class="container">
        <ul class="hero__trust-list">
          <li>Работаем 24/7</li>
          <li>Собственный автопарк</li>
          <li>Оператор включён в стоимость</li>
          <li>Официальный договор</li>
        </ul>
      </div>
    </div>
  </section>

  <main>
    <section class="technics">
      <div class="container">
        <div class="row text-center">
          <div class="col-sm">
            <h2 class="technics__title" id="mainPageCatalog">Каталог спецтехники</h2>
          </div>
        </div>
        <Catalog client:load categories={categories} showFilters={true} />
      </div>
    </section>

    <section class="information">
      <div class="container">
        <h2 class="info__title text-center">Работая с нами вы получите</h2>
        <ul class="advantages-grid">
          <li class="advantage">
            <span class="advantage__icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path>
                <path d="M15 18H9"></path>
                <path
                  d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"
                ></path>
                <circle cx="17" cy="18" r="2"></circle>
                <circle cx="7" cy="18" r="2"></circle>
              </svg>
            </span>
            <b class="advantage__title">Большой выбор техники</b>
            <p class="advantage__text">От мини-погрузчиков до самосвалов-большетонников</p>
          </li>
          <li class="advantage">
            <span class="advantage__icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1 1 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
                ></path>
                <path d="m9 12 2 2 4-4"></path>
              </svg>
            </span>
            <b class="advantage__title">100% исправную технику</b>
            <p class="advantage__text">
              Квалифицированные механики ежедневно поддерживают технику в рабочем состоянии
            </p>
          </li>
          <li class="advantage">
            <span class="advantage__icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path>
                <path d="M14 2v4a2 2 0 0 0 2 2h4"></path>
                <path d="M10 9H8"></path>
                <path d="M16 13H8"></path>
                <path d="M16 17H8"></path>
              </svg>
            </span>
            <b class="advantage__title">Официальный договор</b>
            <p class="advantage__text">
              Договор — гарантия того, что все обязательства будут выполнены
            </p>
          </li>
          <li class="advantage">
            <span class="advantage__icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M8 2v4"></path>
                <path d="M16 2v4"></path>
                <rect width="18" height="18" x="3" y="4" rx="2"></rect>
                <path d="M3 10h18"></path>
              </svg>
            </span>
            <b class="advantage__title">Любой срок аренды</b>
            <p class="advantage__text">От одной смены до постоянного сотрудничества</p>
          </li>
          <li class="advantage">
            <span class="advantage__icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M10 10V5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5"></path>
                <path d="M14 6a6 6 0 0 1 6 6v3"></path>
                <path d="M4 15v-3a6 6 0 0 1 6-6"></path>
                <rect x="2" y="15" width="20" height="4" rx="1"></rect>
              </svg>
            </span>
            <b class="advantage__title">Профессионального оператора</b>
            <p class="advantage__text">В штате — специалисты с большим опытом работы на объектах</p>
          </li>
          <li class="advantage">
            <span class="advantage__icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="19" x2="5" y1="5" y2="19"></line>
                <circle cx="6.5" cy="6.5" r="2.5"></circle>
                <circle cx="17.5" cy="17.5" r="2.5"></circle>
              </svg>
            </span>
            <b class="advantage__title">Скидку на второй заказ</b>
            <p class="advantage__text">Вы помогаете нам развиваться — мы дарим вам скидку</p>
          </li>
        </ul>
      </div>
    </section>

    <section class="information-second">
      <div class="container">
        <div class="row text-center">
          <div class="col">
            <h2 class="info__title">Сотрудничать с нами выгодно</h2>
            <p class="advantages text-left">
              На сегодняшний день <strong>аренда спецтехники в СПб</strong> является популярной услугой
              не только у коммерческих строительных организаций, но и у индивидуальных предпринимателей,
              это обуславливается доступностью стоимости <strong>услуги аренды спецтехники.</strong>
              С минимальными финансовыми вложениями вы сможете арендовать технику и выполнить широкий
              спектр работ. У нас вы можете взять в аренду <strong
                >экскаватор погрузчик с гидромолотом,</strong
              >
              <strong>экскаватор полноповоротный,</strong>
              <strong>автокран 14 тонн,</strong>
              <strong>автокран 40 тонн,</strong>
              <strong>кран манипулятор</strong> и т.д.
            </p>
            <div class="embed-responsive embed-responsive-16by9 col-lg-6 video">
              <video
                width="400"
                height="300"
                controls
                poster="/img/video-poster.png"
                preload="none"
              >
                <source src="/video/terex-plus.mp4" type="video/mp4" />
              </video>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="faq">
      <div class="container">
        <h2 class="info__title text-center">Частые вопросы об аренде</h2>
        <div class="faq__list">
          {
            faq.map((f) => (
              <details class="faq__item">
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <section class="request" id="requestform-section">
      <div class="container">
        <div class="row">
          <ContactForm client:load title="Отправить заявку на аренду/подбор техники" />
        </div>
      </div>
    </section>
  </main>

  <Footer isIndex={true} />
</BaseLayout>
